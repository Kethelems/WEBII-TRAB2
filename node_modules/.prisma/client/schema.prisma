// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:../dev.db"
}

model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  password  String
  cpf       String   @unique
  role      String   @default("comprador")
  /// Conta ativa (admin pode desativar). Cadastros públicos começam ativos após verificar e-mail.
  active           Boolean   @default(true)
  /// Compradores/vendedores devem confirmar o e-mail antes do primeiro login.
  emailVerified    Boolean   @default(true)
  verificationCode   String?
  verificationExpires DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  Products      Product[]
  BuyerProfile  BuyerProfile?
  SellerProfile SellerProfile?
  Comments      Comment[]
  CommentLikes  CommentLike[]
  AuditLogs     AuditLog[]
}

model AuditLog {
  id        Int      @id @default(autoincrement())
  method    String
  path      String
  summary   String
  userId    Int?
  userEmail String?
  createdAt DateTime @default(now())

  User User? @relation(fields: [userId], references: [id], onDelete: SetNull)
}

model BuyerProfile {
  id             Int    @id @default(autoincrement())
  phone          String
  street         String
  city           String
  state          String
  zipCode        String
  paymentMethod  String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  userId         Int    @unique
  User           User   @relation(fields: [userId], references: [id])
}

model SellerProfile {
  id          Int      @id @default(autoincrement())
  storeName   String
  description String
  phone       String
  city        String
  state       String
  categories  String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  userId      Int      @unique
  User        User     @relation(fields: [userId], references: [id])
}

model Product {
  id          Int      @id @default(autoincrement())
  name        String
  description String
  category    String
  price       Float
  stock       Int      @default(0)
  imageUrl    String?
  imageStorage String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  userId      Int
  User        User     @relation(fields: [userId], references: [id])
  
  ProductImages ProductImage[]
  Comments      Comment[]
}

model ProductImage {
  id           Int      @id @default(autoincrement())
  imageUrl     String
  imageStorage String?
  isPrimary    Boolean  @default(false)
  createdAt    DateTime @default(now())

  productId    Int
  Product      Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model Comment {
  id        Int      @id @default(autoincrement())
  content   String
  imageUrl  String?
  imageStorage String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId    Int
  User      User     @relation(fields: [userId], references: [id])
  
  productId Int
  Product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  
  CommentLikes CommentLike[]
}

model CommentLike {
  id        Int      @id @default(autoincrement())
  createdAt DateTime @default(now())

  userId    Int
  User      User     @relation(fields: [userId], references: [id])
  
  commentId Int
  Comment   Comment  @relation(fields: [commentId], references: [id], onDelete: Cascade)
  
  @@unique([userId, commentId])
}


