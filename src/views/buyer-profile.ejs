<%- include('_partials-head', { title: 'Meu Perfil - Comprador' }) %>
      <header class="border-b border-brand-200/80 bg-white/75 backdrop-blur">
        <div class="mx-auto flex max-w-7xl items-center justify-between px-4 py-4 sm:px-6 lg:px-8">
          <a href="/" class="font-display text-xl font-bold">MarketMVP</a>
          <nav class="flex items-center gap-3 text-sm font-semibold">
            <% if (user) { %>
              <span class="text-brand-700">Olá, <%= user.name %></span>
              <form method="POST" action="/logout" class="inline">
                <button type="submit" class="rounded-full border border-brand-300 px-4 py-2 hover:bg-brand-100">Sair</button>
              </form>
            <% } %>
          </nav>
        </div>
      </header>

      <main class="mx-auto max-w-4xl px-4 py-8 sm:px-6 lg:px-8">
        <section class="rounded-3xl border border-brand-200 bg-white p-6 shadow-sm">
          <h1 class="font-display text-3xl font-bold">Meu Perfil de Comprador</h1>
          <p class="mt-1 text-sm text-brand-700">Gerencie suas informações pessoais e preferências de pagamento.</p>

          <% if (error) { %>
            <div class="mt-4 rounded-xl border border-coral-500/30 bg-coral-500/10 px-4 py-3 text-sm font-semibold text-coral-600"><%= error %></div>
          <% } %>
          <% if (success) { %>
            <div class="mt-4 rounded-xl border border-accent-500/30 bg-accent-500/10 px-4 py-3 text-sm font-semibold text-accent-700"><%= success %></div>
          <% } %>

          <form method="POST" action="/buyer/profile" class="mt-6 space-y-4">
            <label class="block">
              <span class="mb-1 block text-sm font-medium">Telefone *</span>
              <input type="text" name="phone" value="<%= profile?.phone || '' %>" required 
                     placeholder="(00) 00000-0000" 
                     class="w-full rounded-xl border border-brand-300 px-4 py-2.5 outline-none ring-coral-500 focus:ring" />
            </label>

            <label class="block">
              <span class="mb-1 block text-sm font-medium">Endereço Completo *</span>
              <input type="text" name="street" value="<%= profile?.street || '' %>" required 
                     placeholder="Rua, número, complemento" 
                     class="w-full rounded-xl border border-brand-300 px-4 py-2.5 outline-none ring-coral-500 focus:ring" />
            </label>

            <div class="grid gap-4 sm:grid-cols-2">
              <label class="block">
                <span class="mb-1 block text-sm font-medium">Cidade *</span>
                <input type="text" name="city" value="<%= profile?.city || '' %>" required 
                       class="w-full rounded-xl border border-brand-300 px-4 py-2.5 outline-none ring-coral-500 focus:ring" />
              </label>

              <label class="block">
                <span class="mb-1 block text-sm font-medium">Estado *</span>
                <input type="text" name="state" value="<%= profile?.state || '' %>" required 
                       placeholder="UF" maxlength="2" 
                       class="w-full rounded-xl border border-brand-300 px-4 py-2.5 outline-none ring-coral-500 focus:ring" />
              </label>
            </div>

            <label class="block">
              <span class="mb-1 block text-sm font-medium">CEP *</span>
              <input type="text" name="zipCode" value="<%= profile?.zipCode || '' %>" required 
                     placeholder="00000-000" 
                     class="w-full rounded-xl border border-brand-300 px-4 py-2.5 outline-none ring-coral-500 focus:ring" />
            </label>

            <label class="block">
              <span class="mb-1 block text-sm font-medium">Forma de Pagamento Preferencial *</span>
              <select name="paymentMethod" required 
                      class="w-full rounded-xl border border-brand-300 px-4 py-2.5 outline-none ring-coral-500 focus:ring">
                <option value="">Selecione...</option>
                <option value="cartao_credito" <%= profile?.paymentMethod === 'cartao_credito' ? 'selected' : '' %>>Cartão de Crédito</option>
                <option value="cartao_debito" <%= profile?.paymentMethod === 'cartao_debito' ? 'selected' : '' %>>Cartão de Débito</option>
                <option value="pix" <%= profile?.paymentMethod === 'pix' ? 'selected' : '' %>>PIX</option>
                <option value="boleto" <%= profile?.paymentMethod === 'boleto' ? 'selected' : '' %>>Boleto</option>
              </select>
            </label>

            <div class="flex gap-3 pt-2">
              <button type="submit" class="flex-1 rounded-xl bg-brand-900 px-4 py-2.5 font-semibold text-brand-50 hover:bg-brand-800">Salvar Perfil</button>
              <a href="/" class="flex-1 rounded-xl border border-brand-300 px-4 py-2.5 text-center font-semibold hover:bg-brand-100">Voltar ao Início</a>
            </div>
          </form>
        </section>
      </main>
<%- include('_partials-footer') %>