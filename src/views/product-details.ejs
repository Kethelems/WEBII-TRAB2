<!DOCTYPE html>\n<html lang=\"pt-BR\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title><%= product.name %> - Marketplace</title>\n    <link href=\"https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css\" rel=\"stylesheet\">\n    <link href=\"https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css\" rel=\"stylesheet\">\n</head>\n<body>\n    <nav class=\"navbar navbar-expand-lg navbar-dark bg-primary\">\n        <div class=\"container\">\n            <a class=\"navbar-brand\" href=\"/\">Marketplace</a>\n            <div class=\"navbar-nav ms-auto\">\n                <% if (user) { %>\n                    <% if (user.role === 'buyer') { %>\n                        <a class=\"nav-link\" href=\"/buyer/profile\">Meu Perfil</a>\n                    <% } else if (user.role === 'seller') { %>\n                        <a class=\"nav-link\" href=\"/seller-dashboard\">Painel</a>\n                    <% } %>\n                    <span class=\"navbar-text me-3\">Olá, <%= user.name %></span>\n                    <form method=\"POST\" action=\"/logout\" class=\"d-inline\">\n                        <button type=\"submit\" class=\"btn btn-outline-light btn-sm\">Sair</button>\n                    </form>\n                <% } else { %>\n                    <a class=\"nav-link\" href=\"/login\">Entrar</a>\n                <% } %>\n            </div>\n        </div>\n    </nav>\n\n    <div class=\"container mt-4\">\n        <nav aria-label=\"breadcrumb\">\n            <ol class=\"breadcrumb\">\n                <li class=\"breadcrumb-item\"><a href=\"/\">Início</a></li>\n                <li class=\"breadcrumb-item\"><%= getProductCategoryLabel(product.category) %></li>\n                <li class=\"breadcrumb-item active\"><%= product.name %></li>\n            </ol>\n        </nav>\n\n        <div class=\"row\">\n            <div class=\"col-md-6\">\n                <!-- Galeria de Imagens -->\n                <% if (product.ProductImages && product.ProductImages.length > 0) { %>\n                    <div id=\"productCarousel\" class=\"carousel slide\" data-bs-ride=\"carousel\">\n                        <div class=\"carousel-inner\">\n                            <% product.ProductImages.forEach((image, index) => { %>\n                                <div class=\"carousel-item <%= index === 0 ? 'active' : '' %>\">\n                                    <img src=\"<%= image.imageUrl %>\" class=\"d-block w-100\" style=\"height: 400px; object-fit: cover;\">\n                                </div>\n                            <% }); %>\n                        </div>\n                        <% if (product.ProductImages.length > 1) { %>\n                            <button class=\"carousel-control-prev\" type=\"button\" data-bs-target=\"#productCarousel\" data-bs-slide=\"prev\">\n                                <span class=\"carousel-control-prev-icon\"></span>\n                            </button>\n                            <button class=\"carousel-control-next\" type=\"button\" data-bs-target=\"#productCarousel\" data-bs-slide=\"next\">\n                                <span class=\"carousel-control-next-icon\"></span>\n                            </button>\n                        <% } %>\n                    </div>\n                <% } else if (product.imageUrl) { %>\n                    <img src=\"<%= product.imageUrl %>\" class=\"img-fluid\" style=\"height: 400px; object-fit: cover; width: 100%;\">\n                <% } else { %>\n                    <div class=\"bg-light d-flex align-items-center justify-content-center\" style=\"height: 400px;\">\n                        <span class=\"text-muted\">Sem imagem</span>\n                    </div>\n                <% } %>\n            </div>\n\n            <div class=\"col-md-6\">\n                <h1><%= product.name %></h1>\n                <p class=\"text-muted\"><%= getProductCategoryLabel(product.category) %></p>\n                <h3 class=\"text-success\">R$ <%= product.price.toFixed(2).replace('.', ',') %></h3>\n                <p><strong>Estoque:</strong> <%= product.stock %> unidades</p>\n                \n                <div class=\"mb-3\">\n                    <h5>Descrição</h5>\n                    <p><%= product.description %></p>\n                </div>\n\n                <!-- Informações do Vendedor -->\n                <div class=\"card mb-3\">\n                    <div class=\"card-body\">\n                        <h6>Vendido por:</h6>\n                        <p class=\"mb-1\">\n                            <a href=\"/seller/<%= product.User.id %>\" class=\"text-decoration-none\">\n                                <strong><%= product.User.SellerProfile?.storeName || product.User.name %></strong>\n                            </a>\n                        </p>\n                        <% if (product.User.SellerProfile) { %>\n                            <small class=\"text-muted\"><%= product.User.SellerProfile.city %>, <%= product.User.SellerProfile.state %></small>\n                        <% } %>\n                    </div>\n                </div>\n\n                <div class=\"mb-3\">\n                    <p><i class=\"fas fa-heart text-danger\"></i> <strong><%= totalLikes %></strong> curtidas nos comentários</p>\n                </div>\n            </div>\n        </div>\n\n        <!-- Seção de Comentários -->\n        <div class=\"row mt-5\">\n            <div class=\"col-12\">\n                <h4>Comentários (<%= product.Comments.length %>)</h4>\n                \n                <% if (user) { %>\n                    <div class=\"card mb-4\">\n                        <div class=\"card-body\">\n                            <form id=\"commentForm\" enctype=\"multipart/form-data\">\n                                <input type=\"hidden\" name=\"productId\" value=\"<%= product.id %>\">\n                                <div class=\"mb-3\">\n                                    <textarea class=\"form-control\" name=\"content\" rows=\"3\" placeholder=\"Deixe seu comentário...\" required></textarea>\n                                </div>\n                                <div class=\"mb-3\">\n                                    <label for=\"commentImage\" class=\"form-label\">Imagem (opcional)</label>\n                                    <input type=\"file\" class=\"form-control\" name=\"image\" accept=\"image/*\">\n                                </div>\n                                <button type=\"submit\" class=\"btn btn-primary\">Comentar</button>\n                            </form>\n                        </div>\n                    </div>\n                <% } else { %>\n                    <div class=\"alert alert-info\">\n                        <a href=\"/login\">Faça login</a> para comentar neste produto.\n                    </div>\n                <% } %>\n\n                <div id=\"commentsContainer\">\n                    <% product.Comments.forEach(comment => { %>\n                        <div class=\"card mb-3\" data-comment-id=\"<%= comment.id %>\">\n                            <div class=\"card-body\">\n                                <div class=\"d-flex justify-content-between align-items-start\">\n                                    <div>\n                                        <h6 class=\"card-title\"><%= comment.User.name %></h6>\n                                        <small class=\"text-muted\"><%= new Date(comment.createdAt).toLocaleString('pt-BR') %></small>\n                                    </div>\n                                    <% if (user && (user.id === comment.userId || user.role === 'admin')) { %>\n                                        <div class=\"dropdown\">\n                                            <button class=\"btn btn-sm btn-outline-secondary dropdown-toggle\" data-bs-toggle=\"dropdown\">\n                                                <i class=\"fas fa-ellipsis-v\"></i>\n                                            </button>\n                                            <ul class=\"dropdown-menu\">\n                                                <% if (user.id === comment.userId) { %>\n                                                    <li><a class=\"dropdown-item edit-comment\" href=\"#\">Editar</a></li>\n                                                <% } %>\n                                                <li><a class=\"dropdown-item delete-comment text-danger\" href=\"#\">Excluir</a></li>\n                                            </ul>\n                                        </div>\n                                    <% } %>\n                                </div>\n                                \n                                <p class=\"comment-content mt-2\"><%= comment.content %></p>\n                                \n                                <% if (comment.imageUrl) { %>\n                                    <img src=\"<%= comment.imageUrl %>\" class=\"img-fluid mt-2\" style=\"max-height: 200px;\">\n                                <% } %>\n                                \n                                <div class=\"mt-2\">\n                                    <% if (user) { %>\n                                        <button class=\"btn btn-sm <%= userLikes[comment.id] ? 'btn-danger' : 'btn-outline-danger' %> like-btn\" \n                                                data-comment-id=\"<%= comment.id %>\">\n                                            <i class=\"fas fa-heart\"></i> \n                                            <span class=\"like-count\"><%= comment.CommentLikes.length %></span>\n                                        </button>\n                                    <% } else { %>\n                                        <span class=\"text-muted\">\n                                            <i class=\"fas fa-heart text-danger\"></i> <%= comment.CommentLikes.length %>\n                                        </span>\n                                    <% } %>\n                                </div>\n                            </div>\n                        </div>\n                    <% }); %>\n                </div>\n            </div>\n        </div>\n    </div>\n\n    <script src=\"https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js\"></script>\n    <script>\n        // Enviar comentário\n        document.getElementById('commentForm')?.addEventListener('submit', async (e) => {\n            e.preventDefault();\n            const formData = new FormData(e.target);\n            \n            try {\n                const response = await fetch('/comments', {\n                    method: 'POST',\n                    body: formData\n                });\n                \n                if (response.ok) {\n                    location.reload();\n                } else {\n                    alert('Erro ao enviar comentário');\n                }\n            } catch (error) {\n                alert('Erro ao enviar comentário');\n            }\n        });\n\n        // Curtir comentário\n        document.querySelectorAll('.like-btn').forEach(btn => {\n            btn.addEventListener('click', async () => {\n                const commentId = btn.dataset.commentId;\n                \n                try {\n                    const response = await fetch(`/comments/${commentId}/like`, {\n                        method: 'POST'\n                    });\n                    \n                    if (response.ok) {\n                        const data = await response.json();\n                        const likeCount = btn.querySelector('.like-count');\n                        const currentCount = parseInt(likeCount.textContent);\n                        \n                        if (data.liked) {\n                            btn.classList.remove('btn-outline-danger');\n                            btn.classList.add('btn-danger');\n                            likeCount.textContent = currentCount + 1;\n                        } else {\n                            btn.classList.remove('btn-danger');\n                            btn.classList.add('btn-outline-danger');\n                            likeCount.textContent = currentCount - 1;\n                        }\n                    }\n                } catch (error) {\n                    alert('Erro ao curtir comentário');\n                }\n            });\n        });\n\n        // Excluir comentário\n        document.querySelectorAll('.delete-comment').forEach(btn => {\n            btn.addEventListener('click', async (e) => {\n                e.preventDefault();\n                \n                if (!confirm('Tem certeza que deseja excluir este comentário?')) return;\n                \n                const commentCard = btn.closest('[data-comment-id]');\n                const commentId = commentCard.dataset.commentId;\n                \n                try {\n                    const response = await fetch(`/comments/${commentId}`, {\n                        method: 'DELETE'\n                    });\n                    \n                    if (response.ok) {\n                        commentCard.remove();\n                    } else {\n                        alert('Erro ao excluir comentário');\n                    }\n                } catch (error) {\n                    alert('Erro ao excluir comentário');\n                }\n            });\n        });\n    </script>\n</body>\n</html>