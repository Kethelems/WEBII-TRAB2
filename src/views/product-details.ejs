<%- include('_partials-head', { title: product.name }) %>
      <header class="border-b border-brand-200/80 bg-white/75 backdrop-blur">
        <div class="mx-auto flex max-w-7xl items-center justify-between px-4 py-4 sm:px-6 lg:px-8">
          <a href="/" class="font-display text-xl font-bold">MarketMVP</a>
          <nav class="flex items-center gap-3 text-sm font-semibold">
            <% if (user) { %>
              <% if (user.role === 'comprador') { %>
                <a href="/buyer/profile" class="text-brand-700 hover:text-brand-900">Meu Perfil</a>
              <% } else if (user.role === 'vendedor') { %>
                <a href="/seller-dashboard" class="text-brand-700 hover:text-brand-900">Painel</a>
              <% } %>
              <span class="text-brand-700">Olá, <%= user.name %></span>
              <form method="POST" action="/logout" class="inline">
                <button type="submit" class="rounded-full border border-brand-300 px-4 py-2 hover:bg-brand-100">Sair</button>
              </form>
            <% } else { %>
              <a href="/login" class="rounded-full border border-brand-300 px-4 py-2 hover:bg-brand-100">Entrar</a>
            <% } %>
          </nav>
        </div>
      </header>

      <main class="mx-auto max-w-7xl px-4 py-8 sm:px-6 lg:px-8">
        <!-- Breadcrumb -->
        <nav class="mb-6 flex items-center gap-2 text-sm text-brand-700">
          <a href="/" class="hover:text-brand-900">Início</a>
          <span>/</span>
          <span><%= getProductCategoryLabel(product.category) %></span>
          <span>/</span>
          <span class="text-brand-900 font-medium"><%= product.name %></span>
        </nav>

        <!-- Produto -->
        <div class="grid gap-8 lg:grid-cols-2">
          <!-- Galeria de Imagens -->
          <div class="rounded-3xl border border-brand-200 bg-white p-4 shadow-sm">
            <% if (product.ProductImages && product.ProductImages.length > 0) { %>
              <div id="mainImage" class="mb-4 overflow-hidden rounded-2xl">
                <img src="<%= product.ProductImages[0].imageUrl %>" class="w-full h-96 object-cover" alt="<%= product.name %>">
              </div>
              <% if (product.ProductImages.length > 1) { %>
                <div class="grid grid-cols-4 gap-2">
                  <% product.ProductImages.forEach((image, index) => { %>
                    <button onclick="changeImage('<%= image.imageUrl %>')" class="overflow-hidden rounded-xl border-2 border-brand-200 hover:border-brand-400 transition">
                      <img src="<%= image.imageUrl %>" class="w-full h-20 object-cover" alt="Imagem <%= index + 1 %>">
                    </button>
                  <% }); %>
                </div>
              <% } %>
            <% } else if (product.imageUrl) { %>
              <img src="<%= product.imageUrl %>" class="w-full h-96 object-cover rounded-2xl" alt="<%= product.name %>">
            <% } else { %>
              <div class="flex items-center justify-center h-96 bg-brand-100 rounded-2xl">
                <span class="text-brand-600">Sem imagem</span>
              </div>
            <% } %>
          </div>

          <!-- Informações do Produto -->
          <div class="space-y-6">
            <div>
              <h1 class="font-display text-4xl font-bold"><%= product.name %></h1>
              <p class="mt-1 text-sm text-brand-600"><%= getProductCategoryLabel(product.category) %></p>
            </div>

            <div class="rounded-2xl bg-accent-500/10 p-4">
              <p class="font-display text-3xl font-bold text-accent-600">R$ <%= product.price.toFixed(2).replace('.', ',') %></p>
              <p class="mt-1 text-sm text-brand-700"><strong>Estoque:</strong> <%= product.stock %> unidades</p>
            </div>

            <div>
              <h3 class="font-display text-lg font-bold">Descrição</h3>
              <p class="mt-2 text-brand-700"><%= product.description %></p>
            </div>

            <!-- Vendedor -->
            <div class="rounded-2xl border border-brand-200 bg-white p-4">
              <h4 class="text-sm font-semibold text-brand-600 uppercase">Vendido por</h4>
              <a href="/seller/<%= product.User.id %>" class="mt-1 block font-display text-xl font-bold text-brand-900 hover:text-accent-600">
                <%= product.User.SellerProfile?.storeName || product.User.name %>
              </a>
              <% if (product.User.SellerProfile) { %>
                <p class="mt-1 text-sm text-brand-600"><%= product.User.SellerProfile.city %>, <%= product.User.SellerProfile.state %></p>
              <% } %>
            </div>

            <div class="flex items-center gap-2 text-coral-600">
              <svg class="w-5 h-5 fill-current" viewBox="0 0 20 20"><path d="M3.172 5.172a4 4 0 015.656 0L10 6.343l1.172-1.171a4 4 0 115.656 5.656L10 17.657l-6.828-6.829a4 4 0 010-5.656z"/></svg>
              <span class="font-semibold"><%= totalLikes %> curtidas nos comentários</span>
            </div>
          </div>
        </div>

        <!-- Comentários -->
        <div class="mt-12">
          <h2 class="font-display text-3xl font-bold">Comentários (<%= product.Comments.length %>)</h2>

          <% if (user) { %>
            <div class="mt-6 rounded-3xl border border-brand-200 bg-white p-6 shadow-sm">
              <form id="commentForm" enctype="multipart/form-data" class="space-y-4">
                <input type="hidden" name="productId" value="<%= product.id %>">
                <label class="block">
                  <span class="mb-1 block text-sm font-medium">Seu comentário</span>
                  <textarea name="content" rows="3" required placeholder="Deixe seu comentário..." 
                            class="w-full rounded-xl border border-brand-300 px-4 py-2.5 outline-none ring-coral-500 focus:ring"></textarea>
                </label>
                <label class="block">
                  <span class="mb-1 block text-sm font-medium">Imagem (opcional)</span>
                  <input type="file" name="image" accept="image/*" 
                         class="w-full rounded-xl border border-brand-300 px-4 py-2.5 outline-none ring-coral-500 focus:ring">
                </label>
                <button type="submit" class="rounded-xl bg-brand-900 px-6 py-2.5 font-semibold text-brand-50 hover:bg-brand-800">
                  Comentar
                </button>
              </form>
            </div>
          <% } else { %>
            <div class="mt-6 rounded-2xl border border-accent-500/30 bg-accent-500/10 px-4 py-3 text-sm">
              <a href="/login" class="font-semibold text-accent-600 hover:underline">Faça login</a> para comentar neste produto.
            </div>
          <% } %>

          <div id="commentsContainer" class="mt-6 space-y-4">
            <% product.Comments.forEach(comment => { %>
              <div class="rounded-3xl border border-brand-200 bg-white p-6 shadow-sm" data-comment-id="<%= comment.id %>">
                <div class="flex items-start justify-between">
                  <div>
                    <h4 class="font-semibold text-brand-900"><%= comment.User.name %></h4>
                    <p class="text-xs text-brand-600"><%= new Date(comment.createdAt).toLocaleString('pt-BR') %></p>
                  </div>
                  <% if (user && (user.id === comment.userId || user.role === 'admin')) { %>
                    <button class="text-brand-600 hover:text-coral-600 delete-comment" title="Excluir">
                      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
                      </svg>
                    </button>
                  <% } %>
                </div>

                <p class="comment-content mt-3 text-brand-700"><%= comment.content %></p>

                <% if (comment.imageUrl) { %>
                  <img src="<%= comment.imageUrl %>" class="mt-3 max-h-48 rounded-xl" alt="Imagem do comentário">
                <% } %>

                <div class="mt-4">
                  <% if (user) { %>
                    <button class="like-btn inline-flex items-center gap-1 rounded-full px-3 py-1 text-sm font-semibold transition <%= userLikes[comment.id] ? 'bg-coral-500 text-white' : 'border border-coral-500 text-coral-600 hover:bg-coral-50' %>" 
                            data-comment-id="<%= comment.id %>">
                      <svg class="w-4 h-4 fill-current" viewBox="0 0 20 20"><path d="M3.172 5.172a4 4 0 015.656 0L10 6.343l1.172-1.171a4 4 0 115.656 5.656L10 17.657l-6.828-6.829a4 4 0 010-5.656z"/></svg>
                      <span class="like-count"><%= comment.CommentLikes.length %></span>
                    </button>
                  <% } else { %>
                    <span class="inline-flex items-center gap-1 text-sm text-brand-600">
                      <svg class="w-4 h-4 fill-coral-500" viewBox="0 0 20 20"><path d="M3.172 5.172a4 4 0 015.656 0L10 6.343l1.172-1.171a4 4 0 115.656 5.656L10 17.657l-6.828-6.829a4 4 0 010-5.656z"/></svg>
                      <%= comment.CommentLikes.length %>
                    </span>
                  <% } %>
                </div>
              </div>
            <% }); %>
          </div>
        </div>
      </main>

      <script>
        function changeImage(url) {
          document.querySelector('#mainImage img').src = url;
        }

        document.getElementById('commentForm')?.addEventListener('submit', async (e) => {
          e.preventDefault();
          const formData = new FormData(e.target);
          
          try {
            const response = await fetch('/comments', {
              method: 'POST',
              body: formData
            });
            
            if (response.ok) {
              location.reload();
            } else {
              alert('Erro ao enviar comentário');
            }
          } catch (error) {
            alert('Erro ao enviar comentário');
          }
        });

        document.querySelectorAll('.like-btn').forEach(btn => {
          btn.addEventListener('click', async () => {
            const commentId = btn.dataset.commentId;
            
            try {
              const response = await fetch(`/comments/${commentId}/like`, {
                method: 'POST'
              });
              
              if (response.ok) {
                const data = await response.json();
                const likeCount = btn.querySelector('.like-count');
                const currentCount = parseInt(likeCount.textContent);
                
                if (data.liked) {
                  btn.classList.remove('border', 'border-coral-500', 'text-coral-600', 'hover:bg-coral-50');
                  btn.classList.add('bg-coral-500', 'text-white');
                  likeCount.textContent = currentCount + 1;
                } else {
                  btn.classList.remove('bg-coral-500', 'text-white');
                  btn.classList.add('border', 'border-coral-500', 'text-coral-600', 'hover:bg-coral-50');
                  likeCount.textContent = currentCount - 1;
                }
              }
            } catch (error) {
              alert('Erro ao curtir comentário');
            }
          });
        });

        document.querySelectorAll('.delete-comment').forEach(btn => {
          btn.addEventListener('click', async (e) => {
            e.preventDefault();
            
            if (!confirm('Tem certeza que deseja excluir este comentário?')) return;
            
            const commentCard = btn.closest('[data-comment-id]');
            const commentId = commentCard.dataset.commentId;
            
            try {
              const response = await fetch(`/comments/${commentId}`, {
                method: 'DELETE'
              });
              
              if (response.ok) {
                commentCard.remove();
              } else {
                alert('Erro ao excluir comentário');
              }
            } catch (error) {
              alert('Erro ao excluir comentário');
            }
          });
        });
      </script>
<%- include('_partials-footer') %>
