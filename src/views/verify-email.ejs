<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>MarketMVP | Verificar e-mail</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;700&family=Plus+Jakarta+Sans:wght@400;600;700&display=swap" rel="stylesheet" />
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
      tailwind.config = {
        theme: {
          extend: {
            fontFamily: {
              display: ["Space Grotesk", "sans-serif"],
              body: ["Plus Jakarta Sans", "sans-serif"],
            },
            colors: {
              brand: { 50: "#F8F7F2", 100: "#EDE8D8", 200: "#D9CEAA", 300: "#C7B57D", 400: "#B99B56", 500: "#A8853A", 600: "#886B2F", 700: "#665024", 800: "#43361A", 900: "#251E10" },
              accent: { 500: "#0A7D7A", 600: "#075F5D" },
              coral: { 500: "#E66A4E", 600: "#C85339" },
            },
          },
        },
      };
    </script>
    <style>
      .grid-bg {
        background-image: radial-gradient(#d9ceaa 0.8px, transparent 0.8px), radial-gradient(#d9ceaa 0.8px, #f8f7f2 0.8px);
        background-size: 28px 28px;
        background-position: 0 0, 14px 14px;
      }
    </style>
  </head>
  <body class="font-body bg-brand-50 text-brand-900">
    <div class="min-h-screen grid-bg">
      <header class="border-b border-brand-200/80 bg-white/75 backdrop-blur">
        <div class="mx-auto flex max-w-7xl items-center justify-between px-4 py-4 sm:px-6 lg:px-8">
          <a href="/" class="font-display text-xl font-bold">MarketMVP</a>
          <a href="/login" class="text-sm font-semibold text-accent-600 hover:underline">Ir para login</a>
        </div>
      </header>

      <main class="mx-auto flex max-w-7xl items-center justify-center px-4 py-10 sm:px-6 lg:px-8">
        <section class="w-full max-w-md rounded-3xl border border-brand-200 bg-white p-6 shadow-sm">
          <h1 class="font-display text-3xl font-bold">Verifique seu e-mail</h1>
          <p class="mt-1 text-sm text-brand-700">
            Insira o código de 6 dígitos enviado para <strong><%= email %></strong>. O código expira em 30 minutos.
          </p>

          <% if (erro) { %>
            <div class="mt-4 rounded-xl bg-coral-500/10 px-4 py-3 text-sm font-semibold text-coral-600"><%= erro %></div>
          <% } %>
          <% if (sucesso) { %>
            <div class="mt-4 rounded-xl bg-accent-500/10 px-4 py-3 text-sm font-semibold text-accent-600">
              <%= sucesso %> <a href="/login" class="underline">Fazer login</a>
            </div>
          <% } %>

          <form method="POST" action="/verificar-email" class="mt-5 space-y-4">
            <input type="hidden" name="email" value="<%= email %>" />
            <label class="block">
              <span class="mb-1 block text-sm font-medium">Código de verificação</span>
              <input
                type="text"
                name="codigo"
                required
                maxlength="6"
                placeholder="000000"
                class="w-full rounded-xl border border-brand-300 px-4 py-2.5 text-center text-2xl tracking-widest outline-none ring-coral-500 focus:ring"
              />
            </label>
            <button type="submit" class="w-full rounded-xl bg-brand-900 px-4 py-2.5 font-semibold text-brand-50 hover:bg-brand-800">Verificar</button>
          </form>

          <form method="POST" action="/reenviar-codigo" class="mt-3">
            <input type="hidden" name="email" value="<%= email %>" />
            <button type="submit" class="w-full rounded-xl border border-brand-300 px-4 py-2.5 text-sm font-semibold hover:bg-brand-100">Reenviar código</button>
          </form>
        </section>
      </main>
    </div>
  </body>
</html>
