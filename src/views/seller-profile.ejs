<!DOCTYPE html>\n<html lang=\"pt-BR\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Meu Perfil - Vendedor</title>\n    <link href=\"https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css\" rel=\"stylesheet\">\n</head>\n<body>\n    <nav class=\"navbar navbar-expand-lg navbar-dark bg-primary\">\n        <div class=\"container\">\n            <a class=\"navbar-brand\" href=\"/\">Marketplace</a>\n            <div class=\"navbar-nav ms-auto\">\n                <% if (user) { %>\n                    <a class=\"nav-link\" href=\"/seller-dashboard\">Painel</a>\n                    <span class=\"navbar-text me-3\">Olá, <%= user.name %></span>\n                    <form method=\"POST\" action=\"/logout\" class=\"d-inline\">\n                        <button type=\"submit\" class=\"btn btn-outline-light btn-sm\">Sair</button>\n                    </form>\n                <% } %>\n            </div>\n        </div>\n    </nav>\n\n    <div class=\"container mt-4\">\n        <div class=\"row\">\n            <div class=\"col-md-8 mx-auto\">\n                <div class=\"card\">\n                    <div class=\"card-header\">\n                        <h4>Meu Perfil de Vendedor</h4>\n                    </div>\n                    <div class=\"card-body\">\n                        <% if (error) { %>\n                            <div class=\"alert alert-danger\"><%= error %></div>\n                        <% } %>\n                        <% if (success) { %>\n                            <div class=\"alert alert-success\"><%= success %></div>\n                        <% } %>\n\n                        <form method=\"POST\" action=\"/seller/profile\">\n                            <div class=\"mb-3\">\n                                <label for=\"storeName\" class=\"form-label\">Nome da Loja *</label>\n                                <input type=\"text\" class=\"form-control\" id=\"storeName\" name=\"storeName\" \n                                       value=\"<%= profile?.storeName || '' %>\" required>\n                            </div>\n\n                            <div class=\"mb-3\">\n                                <label for=\"description\" class=\"form-label\">Descrição da Loja *</label>\n                                <textarea class=\"form-control\" id=\"description\" name=\"description\" rows=\"4\" required><%= profile?.description || '' %></textarea>\n                            </div>\n\n                            <div class=\"mb-3\">\n                                <label for=\"phone\" class=\"form-label\">Telefone Comercial *</label>\n                                <input type=\"text\" class=\"form-control\" id=\"phone\" name=\"phone\" \n                                       value=\"<%= profile?.phone || '' %>\" required>\n                            </div>\n\n                            <div class=\"row\">\n                                <div class=\"col-md-6\">\n                                    <div class=\"mb-3\">\n                                        <label for=\"city\" class=\"form-label\">Cidade *</label>\n                                        <input type=\"text\" class=\"form-control\" id=\"city\" name=\"city\" \n                                               value=\"<%= profile?.city || '' %>\" required>\n                                    </div>\n                                </div>\n                                <div class=\"col-md-6\">\n                                    <div class=\"mb-3\">\n                                        <label for=\"state\" class=\"form-label\">Estado *</label>\n                                        <input type=\"text\" class=\"form-control\" id=\"state\" name=\"state\" \n                                               value=\"<%= profile?.state || '' %>\" required>\n                                    </div>\n                                </div>\n                            </div>\n\n                            <div class=\"mb-3\">\n                                <label for=\"categories\" class=\"form-label\">Categorias de Produtos *</label>\n                                <input type=\"text\" class=\"form-control\" id=\"categories\" name=\"categories\" \n                                       value=\"<%= profile?.categories || '' %>\" \n                                       placeholder=\"Ex: Eletrônicos, Roupas, Casa e Jardim\" required>\n                                <div class=\"form-text\">Separe as categorias por vírgula</div>\n                            </div>\n\n                            <div class=\"d-grid gap-2\">\n                                <button type=\"submit\" class=\"btn btn-primary\">Salvar Perfil</button>\n                                <a href=\"/seller-dashboard\" class=\"btn btn-secondary\">Voltar ao Painel</a>\n                            </div>\n                        </form>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </div>\n\n    <script src=\"https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js\"></script>\n</body>\n</html>