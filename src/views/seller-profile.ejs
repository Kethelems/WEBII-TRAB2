<%- include('_partials-head', { title: 'Meu Perfil - Vendedor' }) %>
      <header class="border-b border-brand-200/80 bg-white/75 backdrop-blur">
        <div class="mx-auto flex max-w-7xl items-center justify-between px-4 py-4 sm:px-6 lg:px-8">
          <a href="/" class="font-display text-xl font-bold">MarketMVP</a>
          <nav class="flex items-center gap-3 text-sm font-semibold">
            <% if (user) { %>
              <a href="/seller-dashboard" class="text-brand-700 hover:text-brand-900">Painel</a>
              <span class="text-brand-700">Olá, <%= user.name %></span>
              <form method="POST" action="/logout" class="inline">
                <button type="submit" class="rounded-full border border-brand-300 px-4 py-2 hover:bg-brand-100">Sair</button>
              </form>
            <% } %>
          </nav>
        </div>
      </header>

      <main class="mx-auto max-w-4xl px-4 py-8 sm:px-6 lg:px-8">
        <section class="rounded-3xl border border-brand-200 bg-white p-6 shadow-sm">
          <h1 class="font-display text-3xl font-bold">Meu Perfil de Vendedor</h1>
          <p class="mt-1 text-sm text-brand-700">Configure as informações da sua loja e categorias de produtos.</p>

          <% if (error) { %>
            <div class="mt-4 rounded-xl border border-coral-500/30 bg-coral-500/10 px-4 py-3 text-sm font-semibold text-coral-600"><%= error %></div>
          <% } %>
          <% if (success) { %>
            <div class="mt-4 rounded-xl border border-accent-500/30 bg-accent-500/10 px-4 py-3 text-sm font-semibold text-accent-700"><%= success %></div>
          <% } %>

          <form method="POST" action="/seller/profile" class="mt-6 space-y-4">
            <label class="block">
              <span class="mb-1 block text-sm font-medium">Nome da Loja *</span>
              <input type="text" name="storeName" value="<%= profile?.storeName || '' %>" required 
                     placeholder="Nome da sua loja" 
                     class="w-full rounded-xl border border-brand-300 px-4 py-2.5 outline-none ring-coral-500 focus:ring" />
            </label>

            <label class="block">
              <span class="mb-1 block text-sm font-medium">Descrição da Loja *</span>
              <textarea name="description" rows="4" required 
                        placeholder="Conte sobre sua loja e produtos" 
                        class="w-full rounded-xl border border-brand-300 px-4 py-2.5 outline-none ring-coral-500 focus:ring"><%= profile?.description || '' %></textarea>
            </label>

            <label class="block">
              <span class="mb-1 block text-sm font-medium">Telefone Comercial *</span>
              <input type="text" name="phone" value="<%= profile?.phone || '' %>" required 
                     placeholder="(00) 00000-0000" 
                     class="w-full rounded-xl border border-brand-300 px-4 py-2.5 outline-none ring-coral-500 focus:ring" />
            </label>

            <div class="grid gap-4 sm:grid-cols-2">
              <label class="block">
                <span class="mb-1 block text-sm font-medium">Cidade *</span>
                <input type="text" name="city" value="<%= profile?.city || '' %>" required 
                       class="w-full rounded-xl border border-brand-300 px-4 py-2.5 outline-none ring-coral-500 focus:ring" />
              </label>

              <label class="block">
                <span class="mb-1 block text-sm font-medium">Estado *</span>
                <input type="text" name="state" value="<%= profile?.state || '' %>" required 
                       placeholder="UF" maxlength="2" 
                       class="w-full rounded-xl border border-brand-300 px-4 py-2.5 outline-none ring-coral-500 focus:ring" />
              </label>
            </div>

            <label class="block">
              <span class="mb-1 block text-sm font-medium">Categorias de Produtos *</span>
              <input type="text" name="categories" value="<%= profile?.categories || '' %>" required 
                     placeholder="Ex: Eletrônicos, Roupas, Casa e Jardim" 
                     class="w-full rounded-xl border border-brand-300 px-4 py-2.5 outline-none ring-coral-500 focus:ring" />
              <p class="mt-1 text-xs text-brand-600">Separe as categorias por vírgula</p>
            </label>

            <div class="flex gap-3 pt-2">
              <button type="submit" class="flex-1 rounded-xl bg-brand-900 px-4 py-2.5 font-semibold text-brand-50 hover:bg-brand-800">Salvar Perfil</button>
              <a href="/seller-dashboard" class="flex-1 rounded-xl border border-brand-300 px-4 py-2.5 text-center font-semibold hover:bg-brand-100">Voltar ao Painel</a>
            </div>
          </form>
        </section>
      </main>
<%- include('_partials-footer') %>