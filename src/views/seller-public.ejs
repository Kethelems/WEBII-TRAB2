<!DOCTYPE html>\n<html lang=\"pt-BR\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title><%= seller.SellerProfile?.storeName || seller.name %> - Vendedor</title>\n    <link href=\"https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css\" rel=\"stylesheet\">\n</head>\n<body>\n    <nav class=\"navbar navbar-expand-lg navbar-dark bg-primary\">\n        <div class=\"container\">\n            <a class=\"navbar-brand\" href=\"/\">Marketplace</a>\n            <div class=\"navbar-nav ms-auto\">\n                <% if (user) { %>\n                    <span class=\"navbar-text me-3\">Olá, <%= user.name %></span>\n                    <form method=\"POST\" action=\"/logout\" class=\"d-inline\">\n                        <button type=\"submit\" class=\"btn btn-outline-light btn-sm\">Sair</button>\n                    </form>\n                <% } else { %>\n                    <a class=\"nav-link\" href=\"/login\">Entrar</a>\n                <% } %>\n            </div>\n        </div>\n    </nav>\n\n    <div class=\"container mt-4\">\n        <div class=\"row\">\n            <div class=\"col-md-4\">\n                <div class=\"card\">\n                    <div class=\"card-header\">\n                        <h5>Informações do Vendedor</h5>\n                    </div>\n                    <div class=\"card-body\">\n                        <h6 class=\"card-title\"><%= seller.SellerProfile?.storeName || seller.name %></h6>\n                        <% if (seller.SellerProfile) { %>\n                            <p class=\"card-text\"><%= seller.SellerProfile.description %></p>\n                            <p><strong>Contato:</strong> <%= seller.SellerProfile.phone %></p>\n                            <p><strong>Localização:</strong> <%= seller.SellerProfile.city %>, <%= seller.SellerProfile.state %></p>\n                            <p><strong>Categorias:</strong> <%= seller.SellerProfile.categories %></p>\n                        <% } else { %>\n                            <p class=\"text-muted\">Perfil não configurado</p>\n                        <% } %>\n                    </div>\n                </div>\n            </div>\n            \n            <div class=\"col-md-8\">\n                <h4>Produtos Recentes</h4>\n                <% if (seller.Products && seller.Products.length > 0) { %>\n                    <div class=\"row\">\n                        <% seller.Products.forEach(product => { %>\n                            <div class=\"col-md-6 mb-3\">\n                                <div class=\"card\">\n                                    <% if (product.imageUrl) { %>\n                                        <img src=\"<%= product.imageUrl %>\" class=\"card-img-top\" style=\"height: 200px; object-fit: cover;\">\n                                    <% } %>\n                                    <div class=\"card-body\">\n                                        <h6 class=\"card-title\"><%= product.name %></h6>\n                                        <p class=\"card-text text-truncate\"><%= product.description %></p>\n                                        <p class=\"text-success\"><strong>R$ <%= product.price.toFixed(2).replace('.', ',') %></strong></p>\n                                        <a href=\"/products/<%= product.id %>\" class=\"btn btn-primary btn-sm\">Ver Detalhes</a>\n                                    </div>\n                                </div>\n                            </div>\n                        <% }); %>\n                    </div>\n                <% } else { %>\n                    <p class=\"text-muted\">Nenhum produto encontrado.</p>\n                <% } %>\n            </div>\n        </div>\n    </div>\n\n    <script src=\"https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js\"></script>\n</body>\n</html>