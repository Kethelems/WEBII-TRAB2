<%- include('_partials-head', { title: seller.SellerProfile?.storeName || seller.name }) %>
      <header class="border-b border-brand-200/80 bg-white/75 backdrop-blur">
        <div class="mx-auto flex max-w-7xl items-center justify-between px-4 py-4 sm:px-6 lg:px-8">
          <a href="/" class="font-display text-xl font-bold">MarketMVP</a>
          <nav class="flex items-center gap-3 text-sm font-semibold">
            <% if (user) { %>
              <span class="text-brand-700">Olá, <%= user.name %></span>
              <form method="POST" action="/logout" class="inline">
                <button type="submit" class="rounded-full border border-brand-300 px-4 py-2 hover:bg-brand-100">Sair</button>
              </form>
            <% } else { %>
              <a href="/login" class="rounded-full border border-brand-300 px-4 py-2 hover:bg-brand-100">Entrar</a>
            <% } %>
          </nav>
        </div>
      </header>

      <main class="mx-auto max-w-7xl px-4 py-8 sm:px-6 lg:px-8">
        <div class="grid gap-8 lg:grid-cols-3">
          <!-- Informações do Vendedor -->
          <div class="lg:col-span-1">
            <div class="rounded-3xl border border-brand-200 bg-white p-6 shadow-sm sticky top-8">
              <h2 class="font-display text-2xl font-bold text-brand-900">
                <%= seller.SellerProfile?.storeName || seller.name %>
              </h2>
              
              <% if (seller.SellerProfile) { %>
                <div class="mt-4 space-y-3 text-sm">
                  <p class="text-brand-700"><%= seller.SellerProfile.description %></p>
                  
                  <div class="flex items-center gap-2 text-brand-600">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
                    </svg>
                    <span><%= seller.SellerProfile.phone %></span>
                  </div>
                  
                  <div class="flex items-center gap-2 text-brand-600">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
                    </svg>
                    <span><%= seller.SellerProfile.city %>, <%= seller.SellerProfile.state %></span>
                  </div>
                  
                  <div class="mt-4 pt-4 border-t border-brand-200">
                    <p class="text-xs font-semibold text-brand-600 uppercase">Categorias</p>
                    <p class="mt-1 text-brand-700"><%= seller.SellerProfile.categories %></p>
                  </div>
                </div>
              <% } else { %>
                <p class="mt-4 text-sm text-brand-600">Perfil não configurado</p>
              <% } %>
            </div>
          </div>

          <!-- Produtos -->
          <div class="lg:col-span-2">
            <h3 class="font-display text-2xl font-bold mb-6">Produtos Recentes</h3>
            
            <% if (seller.Products && seller.Products.length > 0) { %>
              <div class="grid gap-6 sm:grid-cols-2">
                <% seller.Products.forEach(product => { %>
                  <div class="rounded-3xl border border-brand-200 bg-white overflow-hidden shadow-sm hover:shadow-md transition">
                    <% if (product.imageUrl) { %>
                      <img src="<%= product.imageUrl %>" class="w-full h-48 object-cover" alt="<%= product.name %>">
                    <% } else { %>
                      <div class="w-full h-48 bg-brand-100 flex items-center justify-center">
                        <span class="text-brand-600">Sem imagem</span>
                      </div>
                    <% } %>
                    
                    <div class="p-4">
                      <h4 class="font-display text-lg font-bold text-brand-900 line-clamp-1"><%= product.name %></h4>
                      <p class="mt-1 text-sm text-brand-700 line-clamp-2"><%= product.description %></p>
                      <p class="mt-3 font-display text-xl font-bold text-accent-600">
                        R$ <%= product.price.toFixed(2).replace('.', ',') %>
                      </p>
                      <a href="/products/<%= product.id %>" 
                         class="mt-4 block w-full rounded-xl bg-brand-900 px-4 py-2.5 text-center font-semibold text-brand-50 hover:bg-brand-800 transition">
                        Ver Detalhes
                      </a>
                    </div>
                  </div>
                <% }); %>
              </div>
            <% } else { %>
              <div class="rounded-3xl border border-brand-200 bg-white p-12 text-center">
                <p class="text-brand-600">Nenhum produto encontrado.</p>
              </div>
            <% } %>
          </div>
        </div>
      </main>
<%- include('_partials-footer') %>
