<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>MarketMVP | Painel administrativo</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;700&family=Plus+Jakarta+Sans:wght@400;600;700&display=swap" rel="stylesheet" />
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
      tailwind.config = {
        theme: {
          extend: {
            fontFamily: {
              display: ["Space Grotesk", "sans-serif"],
              body: ["Plus Jakarta Sans", "sans-serif"],
            },
            colors: {
              brand: { 50: "#F8F7F2", 100: "#EDE8D8", 200: "#D9CEAA", 300: "#C7B57D", 400: "#B99B56", 500: "#A8853A", 600: "#886B2F", 700: "#665024", 800: "#43361A", 900: "#251E10" },
              accent: { 500: "#0A7D7A", 600: "#075F5D" },
              coral: { 500: "#E66A4E", 600: "#C85339" },
            },
          },
        },
      };
    </script>
    <style>
      .grid-bg {
        background-image: radial-gradient(#d9ceaa 0.8px, transparent 0.8px), radial-gradient(#d9ceaa 0.8px, #f8f7f2 0.8px);
        background-size: 28px 28px;
        background-position: 0 0, 14px 14px;
      }
    </style>
  </head>
  <body class="font-body bg-brand-50 text-brand-900">
    <div class="min-h-screen grid-bg">
      <header class="border-b border-brand-200/80 bg-white/75 backdrop-blur">
        <div class="mx-auto flex max-w-7xl flex-wrap items-center justify-between gap-3 px-4 py-4 sm:px-6 lg:px-8">
          <a href="/admin" class="font-display text-xl font-bold">MarketMVP</a>
          <nav class="flex flex-wrap items-center gap-4 text-sm font-medium">
            <a href="/admin" class="font-semibold text-accent-600">Usuários</a>
            <a href="/admin/logs" class="hover:text-accent-600">Logs</a>
            <a href="/" class="hover:text-accent-600">Loja</a>
          </nav>
          <form method="POST" action="/logout">
            <button type="submit" class="rounded-full border border-brand-300 px-4 py-2 text-sm font-semibold hover:bg-brand-100">Sair</button>
          </form>
        </div>
      </header>

      <main class="mx-auto max-w-7xl space-y-6 px-4 py-8 sm:px-6 lg:px-8">
        <section class="rounded-3xl border border-brand-200 bg-white p-6 shadow-sm">
          <div class="flex flex-wrap items-start justify-between gap-4">
            <div>
              <p class="text-xs font-semibold uppercase tracking-wider text-brand-600">Controle global da plataforma</p>
              <h1 class="mt-1 font-display text-3xl font-bold">Painel administrativo</h1>
            </div>
            <div class="rounded-2xl bg-brand-100 px-4 py-3 text-sm font-semibold text-brand-800"><%= user.name %> — Admin</div>
          </div>
          <div class="mt-5 grid gap-3 sm:grid-cols-3">
            <div class="rounded-2xl bg-brand-100 p-4">
              <p class="text-xs font-semibold uppercase tracking-wider">Contas totais</p>
              <p class="mt-2 font-display text-3xl font-bold"><%= usuarios.length %></p>
            </div>
            <div class="rounded-2xl bg-brand-100 p-4">
              <p class="text-xs font-semibold uppercase tracking-wider">Contas ativas</p>
              <p class="mt-2 font-display text-3xl font-bold"><%= usuarios.filter(function (u) { return u.active; }).length %></p>
            </div>
            <div class="rounded-2xl bg-brand-100 p-4">
              <p class="text-xs font-semibold uppercase tracking-wider">Contas desativadas</p>
              <p class="mt-2 font-display text-3xl font-bold"><%= usuarios.filter(function (u) { return !u.active; }).length %></p>
            </div>
          </div>
        </section>

        <section class="rounded-3xl border border-brand-200 bg-white p-6 shadow-sm">
          <h2 class="font-display text-2xl font-bold">Lista de contas</h2>
          <div class="mt-4 overflow-x-auto rounded-2xl border border-brand-200">
            <table class="min-w-full text-left text-sm">
              <thead class="bg-brand-100 text-brand-800">
                <tr>
                  <th class="px-4 py-3 font-semibold">Nome</th>
                  <th class="px-4 py-3 font-semibold">E-mail</th>
                  <th class="px-4 py-3 font-semibold">Perfil</th>
                  <th class="px-4 py-3 font-semibold">E-mail verif.</th>
                  <th class="px-4 py-3 font-semibold">Status</th>
                  <th class="px-4 py-3 font-semibold">Ações</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-brand-200 bg-white">
                <% usuarios.forEach(function (u) { %>
                <tr>
                  <td class="px-4 py-3 font-semibold"><%= u.name %></td>
                  <td class="px-4 py-3"><%= u.email %></td>
                  <td class="px-4 py-3 capitalize"><%= u.role %></td>
                  <td class="px-4 py-3">
                    <% if (u.emailVerified) { %>
                      <span class="rounded-full bg-accent-500/10 px-2 py-1 text-xs font-semibold text-accent-600">Sim</span>
                    <% } else { %>
                      <span class="rounded-full bg-brand-200 px-2 py-1 text-xs font-semibold text-brand-700">Pendente</span>
                    <% } %>
                  </td>
                  <td class="px-4 py-3">
                    <% if (u.active) { %>
                      <span class="rounded-full bg-accent-500/10 px-2 py-1 text-xs font-semibold text-accent-600">Ativo</span>
                    <% } else { %>
                      <span class="rounded-full bg-brand-200 px-2 py-1 text-xs font-semibold text-brand-700">Inativo</span>
                    <% } %>
                  </td>
                  <td class="px-4 py-3">
                    <% if (u.id !== user.id) { %>
                      <form method="POST" action="/admin/usuarios/<%= u.id %>/status">
                        <button
                          type="submit"
                          class="<%= u.active ? 'bg-coral-500 text-white hover:bg-coral-600' : 'border border-brand-300 hover:bg-brand-100' %> rounded-lg px-3 py-1.5 font-semibold"
                        >
                          <%= u.active ? 'Desativar' : 'Reativar' %>
                        </button>
                      </form>
                    <% } else { %>
                      <span class="text-xs text-brand-500">Você mesmo</span>
                    <% } %>
                  </td>
                </tr>
                <% }); %>
              </tbody>
            </table>
          </div>
        </section>
      </main>
    </div>
  </body>
</html>
