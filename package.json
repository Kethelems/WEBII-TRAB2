{
    "name": "marketplace-trabalho2",
    "version": "2.0.0",
    "description": "Marketplace com perfis completos, múltiplas imagens e sistema de comentários com curtidas",
    "main": "dist/index.js",
    "scripts": {
        "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
        "dev:container": "ts-node-dev --respawn --transpile-only --poll src/index.ts",
        "dev:docker": "docker compose --profile dev up --build app-dev",
        "dev:docker:down": "docker compose --profile dev down",
        "build": "tsc",
        "start": "node dist/index.js",
        "migrate": "npx prisma migrate dev",
        "migrate:reset": "npx prisma migrate reset",
        "db:generate": "npx prisma generate",
        "db:studio": "npx prisma studio",
        "db:seed": "npx prisma db seed",
        "setup": "npm install && npm run migrate && npm run db:generate && npm run db:seed"
    },
    "prisma": {
        "seed": "npx ts-node --compiler-options {\"module\":\"CommonJS\"} prisma/seed.ts"
    },
    "keywords": [
        "marketplace",
        "typescript",
        "express",
        "prisma",
        "docker"
    ],
    "author": "",
    "license": "ISC",
    "type": "commonjs",
    "dependencies": {
        "@aws-sdk/client-s3": "^3.910.0",
        "@prisma/client": "5.9.1",
        "better-sqlite3": "^12.8.0",
        "dotenv": "^17.3.1",
        "ejs": "4.0.1",
        "express": "4.21.2",
        "express-session": "^1.19.0",
        "multer": "^2.0.2",
        "nodemailer": "^8.0.7",
        "sqlite": "^5.1.1",
        "sqlite3": "5.1.7",
        "zod": "^4.3.6"
    },
    "devDependencies": {
        "@types/better-sqlite3": "^7.6.13",
        "@types/express": "4.17.21",
        "@types/express-session": "^1.18.2",
        "@types/multer": "^2.0.0",
        "@types/node": "22.13.10",
        "@types/nodemailer": "^8.0.0",
        "prisma": "5.9.1",
        "ts-node-dev": "2.0.0",
        "typescript": "5.8.2"
    }
}
